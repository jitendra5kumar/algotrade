{
  "name": "algotrade-new-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:backend": "cd backend && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:backend\"",
    "build": "next build",
    "build:backend": "cd backend && npm run build",
    "start": "next start",
    "start:backend": "cd backend && npm start",
    "install:backend": "cd backend && npm install",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:backend": "cd backend && tsc -p tsconfig.json --noEmit",
    "convert:js2ts:dry": "node scripts/convert-js-to-ts.mjs --dry --nocheck",
    "convert:js2ts": "node scripts/convert-js-to-ts.mjs --nocheck",
    "ts:nocheck": "node scripts/add-ts-nocheck.mjs"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "compression": "^1.7.4",
    "cookie": "^1.0.2",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.24",
    "jest": "^30.2.0",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.546.0",
    "mongoose": "^8.19.2",
    "next": "15.5.6",
    "parser": "^0.1.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hot-toast": "^2.6.0",
    "socket.io-client": "~2.2.0",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "concurrently": "^8.2.2",
    "eslint": "^9.38.0",
    "eslint-config-next": "15.5.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
